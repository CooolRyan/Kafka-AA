[Unit]
Description=Apache Kafka MirrorMaker 2 (dedicated)
After=network-online.target kafka.service
Wants=network-online.target

[Service]
Type=simple
User=kafka
Group=kafka
Environment="JAVA_HOME=/usr/lib/jvm/jre-17"
Environment="KAFKA_HEAP_OPTS=-Xmx768m -Xms768m"
ExecStart=/opt/kafka/bin/connect-mirror-maker.sh /etc/kafka/mm2-remote.properties
Restart=on-failure
RestartSec=15
LimitNOFILE=100000

[Install]
WantedBy=multi-user.target
